{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Weekly lock file maintenance and suppression of non-breaking Rust, JavaScript, and Python update PRs.",
  "extends": ["github>rust-lang/renovate:base"],
  "lockFileMaintenance": {
    "enabled": true,
    "extends": ["schedule:weekly"]
  },
  "packageRules": [
    {
      "matchCategories": ["rust", "js", "python"],
      "enabled": true
    },
    {
      "matchCategories": ["rust", "js", "python"],
      "matchJsonata": ["isBreaking != true"],
      "enabled": false
    }
  ]
}
